# ─── Telegram ────────────────────────────────────────────────────────────────
# Get your token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat/channel ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Binance ─────────────────────────────────────────────────────────────────
# Create API keys at https://www.binance.com/en/my/settings/api-management
# Required permissions: Read Only (no trading permissions needed)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# ─── Bot Settings ────────────────────────────────────────────────────────────
# Comma-separated list of trading pairs to monitor
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT

# Candle timeframe: 1m, 3m, 5m, 15m, 30m, 1h, 4h, 1d
TIMEFRAME=15m

# How often to check for signals (in seconds)
CHECK_INTERVAL=30

# Bot display name in Telegram messages
BOT_NAME=My Signal Bot
