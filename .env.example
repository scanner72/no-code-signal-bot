# Binance API (for data ingestion)
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret

# Trading pairs tracked by the bot (comma-separated, no spaces)
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token

# Database
DB_HOST=timescaledb
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=signalbot

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Auth (better-auth). For a server deployment set these to your public URL,
# e.g. http://YOUR_SERVER_IP. Leave as localhost for local Docker.
BETTER_AUTH_URL=http://localhost/api/auth
TRUSTED_ORIGINS=http://localhost

# heym MCP Integration (http://localhost:4017)
# 1. Open heym UI → MCP tab → click "Generate" to create API key
# 2. Paste the key below
# 3. Create "Signal Validator" workflow in heym and paste its ID
HEYM_API_URL=http://localhost:4017/api
HEYM_API_KEY=
HEYM_SIGNAL_VALIDATOR_ID=
